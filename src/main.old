use crossterm::{
    event::{poll, read, Event, KeyCode},
    execute,
    terminal::{enable_raw_mode, disable_raw_mode, EnterAlternateScreen, LeaveAlternateScreen},
};
use ratatui::{
    backend::CrosstermBackend,
    layout::{Constraint, Direction, Layout},
    widgets::{Block, Borders, Paragraph},
    Terminal,
};
use std::{
    process::{Child, Command, Stdio},
    sync::{Arc, Mutex},
    thread,
    time::Duration,
};
use rand::Rng; // for gen_range
use rand::thread_rng; // top-level, works in 0.8


// ----------------- Stations -----------------
struct Station {
    name: &'static str,
    url: &'static str,
}

const STATIONS: &[Station] = &[
    Station {
        name: "VOCM AM 590",
        url: "https://stingray.leanstream.co/VOCMAM",
    },
    Station {
        name: "CBC Radio One",
        url: "https://cbcradiolive.akamaized.net/hls/live/2037435/ES_R1NSN/adaptive_48/chunklist_ao.m3u8",
    },
    Station {
        name: "VOWR 800",
        url: "https://c21.radioboss.fm/stream/193",
    },
    Station {
        name: "CHMR 93.5 FM",
        url: "http://192.99.14.49:9005/live128",
    }
];

// ----------------- App State -----------------
struct AppState {
    current_station: usize,
    status: String,
    spectrum: Vec<u8>,
    spinner_index: usize,
    player: Option<Child>,
}

impl AppState {
    fn new() -> Self {
        Self {
            current_station: 0,
            status: "OFFLINE".to_string(),
            spectrum: vec![0; 20],
            spinner_index: 0,
            player: None,
        }
    }
}

// ----------------- Audio Control -----------------
fn play(app: &mut AppState) {
    stop(app);

    let station = &STATIONS[app.current_station];
    let child = Command::new("ffplay")
        .arg("-nodisp")
        .arg("-loglevel")
        .arg("quiet")
        .arg(station.url)
        .stdout(Stdio::null())
        .stderr(Stdio::null())
        .spawn();

    match child {
        Ok(p) => {
            app.player = Some(p);
            app.status = "ONLINE".to_string();
        }
        Err(e) => {
            app.status = format!("FAILED: {}", e);
        }
    }
}

fn stop(app: &mut AppState) {
    if let Some(ref mut p) = app.player {
        let _ = p.kill();
    }
    app.player = None;
    app.status = "OFFLINE".to_string();
}

// ----------------- Spectrum -----------------
fn update_spectrum(app: &mut AppState) {
    let mut rng = thread_rng(); // ✅ works in rand 0.8
    for v in &mut app.spectrum {
        if app.status == "ONLINE" {
            let delta: i8 = rng.gen_range(-2..=3);
            *v = ((*v as i8 + delta).clamp(0, 8)) as u8;
        } else {
            *v = v.saturating_sub(1);
        }
    }
    app.spinner_index = (app.spinner_index + 1) % 4;
}


// ----------------- UI -----------------
fn draw_ui(app: &AppState, terminal: &mut Terminal<CrosstermBackend<std::io::Stdout>>) -> Result<(), std::io::Error> {
    terminal.draw(|f| {
        let size = f.size();

        let chunks = Layout::default()
            .direction(Direction::Vertical)
            .margin(2)
            .constraints(
                [
                    Constraint::Length(3),
                    Constraint::Length(3),
                    Constraint::Length(4),
                    Constraint::Length(6),
                ]
                .as_ref(),
            )
            .split(size);

        // Title
        let title = Paragraph::new(format!("{} - Townie Radio", STATIONS[app.current_station].name))
            .block(Block::default().borders(Borders::ALL));
        f.render_widget(title, chunks[0]);

        // Status
        let spinner = ["|", "/", "-", "\\"][app.spinner_index];
        let status = Paragraph::new(format!("STATUS: {} {}", app.status, spinner))
            .block(Block::default().borders(Borders::ALL));
        f.render_widget(status, chunks[1]);

        // Spectrum
        let spectrum_str: String = app.spectrum.iter()
            .map(|&v| std::iter::repeat("█").take(v as usize).collect::<String>())
            .collect::<Vec<_>>()
            .join(" ");
        let spectrum_widget = Paragraph::new(spectrum_str)
            .block(Block::default().borders(Borders::ALL).title("SPECTRUM"));
        f.render_widget(spectrum_widget, chunks[2]);

        // Stations / Controls
        let mut station_lines = vec![];
        for (i, s) in STATIONS.iter().enumerate() {
            if i == app.current_station {
                station_lines.push(format!("> [{}] {}", i + 1, s.name));
            } else {
                station_lines.push(format!("  [{}] {}", i + 1, s.name));
            }
        }
        let stations_paragraph = Paragraph::new(station_lines.join("\n"))
            .block(Block::default().borders(Borders::ALL).title("STATIONS/CONTROLS"));
        f.render_widget(stations_paragraph, chunks[3]);
    })?;
    Ok(())
}

// ----------------- Main -----------------
fn main() -> Result<(), Box<dyn std::error::Error>> {
    let mut stdout = std::io::stdout();
    enable_raw_mode()?;
    execute!(stdout, EnterAlternateScreen)?;

    let backend = CrosstermBackend::new(stdout);
    let mut terminal = Terminal::new(backend)?;

    let app = Arc::new(Mutex::new(AppState::new()));

    // Spectrum update thread
    let app_clone = Arc::clone(&app);
    thread::spawn(move || {
        loop {
            {
                let mut a = app_clone.lock().unwrap();
                update_spectrum(&mut a);
            }
            thread::sleep(Duration::from_millis(80));
        }
    });

    loop {
        {
            let a = app.lock().unwrap();
            draw_ui(&a, &mut terminal)?;
        }

        if poll(Duration::from_millis(50))? {
            if let Event::Key(key) = read()? {
                let mut a = app.lock().unwrap();
                match key.code {
                    KeyCode::Char('q') => {
                        stop(&mut a);
                        break;
                    }
                    KeyCode::Char('p') => play(&mut a),
                    KeyCode::Char('s') => stop(&mut a),
                    KeyCode::Char(c) => {
                        if let Some(digit) = c.to_digit(10) {
                            let idx = (digit - 1) as usize;
                            if idx < STATIONS.len() {
                                stop(&mut a);
                                a.current_station = idx;
                                play(&mut a);
                            }
                        }
                    }
                    _ => {}
                }
            }
        }
    }

    disable_raw_mode()?;
    execute!(terminal.backend_mut(), LeaveAlternateScreen)?;
    terminal.show_cursor()?;
    Ok(())
}
